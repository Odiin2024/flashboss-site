    "trigger_card_number": 65,
    "title": "LESSON 2: ARTICLES & ELISION",
    "header_color": "green",
    "pages": [
      {
        "page": 1,
        "total_pages": 2,
        "content": [
          "Italian articles change with sound,",
          "not just gender. It's phonological:",
          "",
          "MASCULINE SINGULAR:                  Press 1",
          "   il = before most consonants",
          "      il libro, il padre, il cane",
          "   lo = before z, gn, ps, s+consonant",
          "      lo zio, lo gnocco, lo stato",
          "",
          "FEMININE SINGULAR:                   Press 2",
          "   la = before any consonant",
          "      la casa, la madre, la zia",
          "",
          "PLURALS:                             Press 3",
          "   i, gli (m pl); le (f pl, always)",
          "      i libri, gli stati, le case"
        ],
        "pronunciation": "Lezione due",
        "pronunciation_mappings": {
          "1": "il. libro. il. padre. il. cane. lo. stato. lo. zio. lo. gnocco",
          "2": "la. casa. la. madre. la. zia",
          "3": "i. libri. gli. stati. le. case"
        }
      },
      {
        "page": 2,
        "total_pages": 2,
        "content": [
          "ELISION — the apostrophe rule:",
          "",
          "Before a vowel, singular articles",
          "drop their final letter and add ':    Press 1",
          "",
          "   il / la / lo + vowel → l'",
          "      l'amico (m), l'aria (f)",
          "      l'ora, l'uomo, l'occhio",
          "",
          "PLURALS DO NOT ELIDE:                Press 2",
          "   gli amici (NOT gl'amici)",
          "   le ore (NOT l'ore)",
          "",
          "GENDER STILL MATTERS:                Press 3",
          "   l'uomo (m) → un uomo, gli uomini",
          "   l'aria (f) → un'aria, le arie",
          "",
          "Cards show Elides: true on these."
        ],
        "pronunciation_mappings": {
          "1": "l'amico. l'aria. l'ora. l'uomo. l'occhio",
          "2": "gli. amici. le. ore",
          "3": "l'uomo. un. uomo. gli. uomini. l'aria. un'aria. le. arie"
        }
      }
    ]
  },
