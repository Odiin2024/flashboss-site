          "native speakers included.",
          "",
          "bought = past tense of buy",
          "brought = past tense of bring",
          "",
          "affect = the verb (it affects me)",
          "effect = the noun (the effect)",
          "",
          "stationARy = stAying still",
          "stationERy = papER",
          "",
          "Emigrate = Exit a country",
          "Immigrate = Into a country",
          "",
