    "header_color": "cyan",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "Demonstratives point to specific things:",
          "",
          "dieser = this     jener = that (formal)",
          "solcher = such    welcher = which",
          "",
          "DECLENSION (like 'der' articles!):",
          "          Masc    Fem     Neut    Plural",
          "NOM:      dieser  diese   dieses  diese",
          "AKK:      diesen  diese   dieses  diese",
          "DAT:      diesem  dieser  diesem  diesen",
          "",
          "EXAMPLES:",
          "Dieser Mann ist nett. (This man is nice)",
          "Ich kenne diese Frau. (I know this woman)",
          "Dieses Buch ist gut. (This book is good)",
          "",
          "NOTE: 'jener' (that) is formal/literary.",
          "In speech, use 'der/die/das da' instead:",
          "Der Mann da. (That man there)"
        ],
        "pronunciation": "Lektion zwanzig"
      }
    ]
  },
