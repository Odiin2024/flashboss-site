    "header_color": "cyan",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "Use Konjunktiv II for POLITE requests:",
          "",
          "POLITE MODAL FORMS:",
          "können → könnten  (could you...?)",
          "dürfen → dürfte   (might I...?)",
          "mögen → möchte    (would like)",
          "haben → hätte     (would have)",
          "sein → wäre       (would be)",
          "",
          "WÜRDE + INFINITIVE (general conditional):",
          "Ich würde gehen. (I would go)",
          "",
          "Würden Sie mir helfen, den Tisch zu bewegen?",
          "(Would you help me move the table?)",
          "",
          "EXAMPLES:",
          "Könnten Sie mir helfen? (Could you help me?)",
          "Dürfte ich fragen? (Might I ask?)",
          "Ich hätte gern einen Kaffee. (I'd like coffee)"
        ],
        "pronunciation": "Lektion fünfundzwanzig"
      }
    ]
  },
