    "header_color": "cyan",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "Adjectives BEFORE nouns need endings:",
          "",
          "AFTER DER/DIE/DAS (Weak Endings):",
          "der fleißige Student (the diligent student)",
          "die fleißige Studentin",
          "das fleißige Kind",
          "",
          "AFTER EIN/EINE (Mixed Endings):",
          "ein fleißiger Student",
          "eine fleißige Studentin",
          "ein fleißiges Kind",
          "",
          "NO ENDING when adjective comes AFTER verb:",
          "Der Student ist fleißig. (no ending!)",
          "",
          "PATTERN: After der/die/das, you'll usually",
          "see -e (nominative, the most common case).",
          "",
          "Full tables in next lesson!"
        ],
        "pronunciation": "Lektion sechsundzwanzig"
      }
    ]
  },
