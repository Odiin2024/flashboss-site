    "title": "LESSON 36: STRONG ADJECTIVE ENDINGS",
    "header_color": "cyan",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "When there's NO ARTICLE, adjectives must show",
          "gender/case themselves (strong endings):",
          "",
          "STRONG ENDINGS (no article):",
          "          Masc    Fem     Neut    Plural",
          "NOM:      -er     -e      -es     -e",
          "AKK:      -en     -e      -es     -e",
          "DAT:      -em     -er     -em     -en",
          "GEN:      -en     -er     -en     -er",
          "",
          "EXAMPLES:",
          "begabter Student (talented student - masc nom)",
          "begabte Studentin (talented student - fem nom)",
          "begabtes Kind (talented child - neut nom)",
          "",
          "WITH QUANTITIES:",
          "viele begabte Studenten (many talented students)",
          "wenig begabte Leute (few talented people)",
          "",
          "Adjective shows what article would have shown!"
        ],
        "pronunciation": "Lektion 36"
      }
    ]
  },
