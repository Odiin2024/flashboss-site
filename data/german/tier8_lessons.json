    "lesson_id": "037",
    "trigger_word": "Bildung",
    "trigger_card_number": 478,
    "title": "LESSON 37: NOMINALIZATION",
    "header_color": "cyan",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "Turn VERBS and ADJECTIVES into NOUNS:",
          "",
          "VERBS → NEUTER NOUNS (always \"das\"):",
          "lesen → das Lesen (reading)",
          "schreiben → das Schreiben (writing)",
          "bilden → die Bildung (education/formation)",
          "",
          "Always capitalized!",
          "",
          "COMMON WITH PREPOSITIONS:",
          "beim Lesen (while reading)",
          "zum Schreiben (for writing)",
          "zur Weiterbildung (for continuing education)",
          "",
          "ADJECTIVES → NOUNS:",
          "gut → das Gute (the good)",
          "neu → das Neue (the new)",
          "schön → das Schöne (the beautiful)",
          "",
          "Very common in bureaucratic/academic German"
        ],
        "pronunciation": "Lektion 37"
      }
    ]
  },
