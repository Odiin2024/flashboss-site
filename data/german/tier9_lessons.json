    "header_color": "cyan",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "When modal verbs appear in PERFECT tense,",
          "they use a double infinitive construction:",
          "",
          "STRUCTURE: haben + infinitive + modal infinitive",
          "",
          "EXAMPLES:",
          "Früher habe ich das machen können.",
          "(Earlier I was able to do that)",
          "",
          "Er hat nicht kommen wollen.",
          "(He didn't want to come)",
          "",
          "Sie hat früh gehen müssen.",
          "(She had to leave early)",
          "",
          "IN SUBORDINATE CLAUSES:",
          "The auxiliary 'haben' goes BEFORE the infinitives:",
          "Ich weiß, dass er hat kommen wollen.",
          "(I know that he wanted to come)",
          "",
          "Also applies to: lassen, sehen, hören, helfen",
          "Ich habe ihn kommen sehen. (I saw him come)"
        ],
        "pronunciation": "Lektion 54"
      }
    ]
  }
