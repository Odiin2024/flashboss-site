          "HIN = motion AWAY from speaker",
          "HER = motion TOWARD speaker",
          "",
          "BASIC FORMS:",
          "hin = (to) there    her = (to) here",
          "Wo gehst du hin? (Where are you going?)",
          "Komm her! (Come here!)",
          "",
          "COMBINED WITH ADVERBS:",
          "hierhin = to here    hierher = to here",
          "dorthin = to there   dorther = from there",
          "wohin = where to     woher = where from",
          "",
          "COMBINED WITH PREPOSITIONS:",
          "hinaus = out (away)   heraus = out (toward)",
          "hinein = in (away)    herein = in (toward)",
          "hinauf = up (away)    herauf = up (toward)",
          "hinunter = down (away) herunter = down (toward)",
          "",
          "Komm herein! (Come in! - toward speaker)",
          "Geh hinaus! (Go out! - away from speaker)"
