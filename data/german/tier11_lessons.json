    "header_color": "cyan",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "Konjunktiv I is used for indirect speech:",
          "",
          "DIRECT SPEECH:",
          "Er sagt: \"Ich bin müde.\"",
          "(He says: \"I am tired.\")",
          "",
          "INDIRECT SPEECH (Konjunktiv I):",
          "Er sagt, er sei müde.",
          "(He says he is tired)",
          "",
          "FORMATION:",
          "Take the stem, add: -e, -est, -e, -en, -et, -en",
          "",
          "sein → ich sei, du seiest, er sei",
          "haben → ich habe, du habest, er habe",
          "",
          "Er sagt, er habe keine Zeit.",
          "(He says he has no time)",
          "",
          "Common in news reports and formal writing"
        ],
        "pronunciation": "Lektion 56"
      }
    ]
  },
