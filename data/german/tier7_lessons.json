    "header_color": "cyan",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "German creates feminine profession forms by",
          "adding -IN to the masculine form:",
          "",
          "COMMON PATTERN:",
          "der Lehrer → die Lehrerin (teacher)",
          "der Arzt → die Ärztin (doctor)",
          "der Student → die Studentin (student)",
          "der Kollege → die Kollegin (colleague)",
          "",
          "PRONUNCIATION NOTE:",
          "The emphasis remains on the final syllable.",
          "",
          "SHORTHAND NOTATION:",
          "From this point forward, professions will be",
          "shown as: Lehrer/in, Arzt/Ärztin, Student/in",
          "",
          "This means: both masculine and feminine forms",
          "exist following the -in pattern.",
          "",
          "EXCEPTIONS: Some professions have irregular",
          "forms or use different words entirely, but",
          "the -in suffix works for 95% of professions!"
        ],
        "pronunciation": "Lektion 44"
      }
    ]
  },
