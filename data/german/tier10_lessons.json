    "title": "LESSON 53: PAST PERFECT",
    "header_color": "cyan",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "Past Perfect shows what happened BEFORE another",
          "past event:",
          "",
          "STRUCTURE: hatte/war + past participle",
          "(Same as English: had + past verb)",
          "",
          "Same haben/sein rules as perfect tense:",
          "Motion/change → war, Everything else → hatte",
          "",
          "Ich hatte gegessen. (I had eaten)",
          "Er war gegangen. (He had gone)",
          "",
          "WITH 'NACHDEM' (after):",
          "Nachdem ich gegessen hatte, ging ich spazieren.",
          "(After I had eaten, I went for a walk)",
          "",
          "Nachdem sie gegangen war, rief er an.",
          "(After she had left, he called)",
          "",
          "'nachdem' + past perfect → main clause in past"
        ],
        "pronunciation": "Lektion 53"
      }
    ]
  },
