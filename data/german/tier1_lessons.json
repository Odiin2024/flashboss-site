          "",
          "wer    = who      was    = what",
          "wann   = when     wo     = where",
          "warum  = why      wie    = how",
          "welche = which",
          "",
          "WORD ORDER: Question word → VERB → subject",
          "",
          "Was machst du heute?",
          "(What are you doing today?)",
          "",
          "YES/NO QUESTIONS: Start with the verb!",
          "Gehst du nach Hause?",
          "(Are you going home?)"
        ],
        "pronunciation": "Lektion drei"
      }
    ]
