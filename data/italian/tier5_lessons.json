    "header_color": "green",
    "pages": [
      {
        "page": 1,
        "total_pages": 2,
        "content": [
          "FUTURO SEMPLICE = future tense.",
          "For predictions, plans, promises.",
          "",
          "ENDINGS — same for all 3 conjugations:",
          "",
          "   parlare → parler-",
          "      parlerò, parlerai, parlerà,",
          "      parleremo, parlerete, parleranno",
          "",
          "   scrivere → scriver-",
          "      scriverò, scriverai, scriverà,",
          "      scriveremo, scriverete, scriveranno",
          "",
          "   finire → finir-",
          "      finirò, finirai, finirà,",
          "      finiremo, finirete, finiranno",
          "",
          "Note: -are uses -er- stem (not -ar-)."
        ],
        "pronunciation": "Lezione diciannove"
      },
      {
        "page": 2,
        "total_pages": 2,
        "content": [
          "IRREGULAR FUTURE STEMS — endings same:",
          "",
          "   essere → sar-      sarò, sarà...",
          "   avere  → avr-      avrò, avrà...",
          "   andare → andr-     andrò...",
          "   venire → verr-     verrò...",
          "   fare   → far-      farò...",
          "   dire   → dir-      dirò...",
          "   volere → vorr-     vorrò...",
          "   potere → potr-     potrò...",
          "   dovere → dovr-     dovrò...",
          "   sapere → sapr-     saprò...",
          "   vedere → vedr-     vedrò...",
          "",
          "USES:",
          "   - simple future: domani partirò",
          "   - prediction: pioverà",
          "   - conjecture: sarà a casa? (must be?)"
        ]
      }
    ]
  },
