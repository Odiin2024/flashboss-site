      {
        "page": 1,
        "total_pages": 2,
        "content": [
          "NE — replaces 'of/about/from it/them':",
          "",
          "   QUANTITIES (partitive):",
          "      hai libri? — sì, ne ho tre.",
          "         (yes, I have three of them)",
          "      vuoi del pane? — ne voglio un po'.",
          "",
          "   ABOUT something:",
          "      parli del progetto? — sì, ne parlo.",
          "      che ne pensi? = what do you think?",
          "",
          "   FROM a place:",
          "      torni da Roma? — sì, ne torno domani.",
          "         (yes, I return from there tomorrow)",
          "",
          "POSITION: before verb, attach to infin.",
          "PAST AGREEMENT with quantity:",
          "   ne ho mangiati tre (m pl), -e (f pl)"
        ],
        "pronunciation": "Lezione diciotto"
      },
      {
        "page": 2,
        "total_pages": 2,
        "content": [
          "CI — replaces 'to/at/about it' or place:",
          "",
          "   TO/AT a place:",
          "      vai a Roma? — sì, ci vado.",
          "      sei in Italia? — sì, ci sono.",
          "",
          "   ABOUT/IN something abstract:",
          "      credi ai fantasmi? — non ci credo.",
          "      pensi al futuro? — sì, ci penso.",
          "",
          "   IDIOMATIC ESSERCI:",
          "      c'è / ci sono = there is / are",
          "      c'era / c'erano = there was / were",
          "",
          "DOUBLE PRONOUNS — 'i' becomes 'e':",
          "   me lo, te la, ce ne, glielo,",
          "   indirect comes BEFORE direct.",
          "   ce lo dice = he tells it to us"
        ]
      }
    ]
