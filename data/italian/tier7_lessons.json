    "header_color": "magenta",
    "pages": [
      {
        "page": 1,
        "total_pages": 5,
        "content": [
          "The CONGIUNTIVO (subjunctive) expresses",
          "doubt, desire, opinion, or emotion —",
          "anything that isn't a stated fact.",
          "",
          "INDICATIVE (fact):",
          "   Marco parla italiano.",
          "   Marco speaks Italian.",
          "",
          "SUBJUNCTIVE (opinion/doubt):",
          "   Penso che Marco parli italiano.",
          "   I think Marco speaks Italian.",
          "",
          "TRIGGERS — verbs that need 'che' +",
          "subjunctive in the second clause:",
          "   pensare, credere, sperare,",
          "   temere, dubitare, volere,",
          "   preferire, sembrare, parere..."
        ],
        "pronunciation": "Penso che sia vero."
      },
      {
        "page": 2,
        "total_pages": 5,
        "content": [
          "PRESENT SUBJUNCTIVE — essere & avere:",
          "",
          "ESSERE:",
          "   che io       sia",
          "   che tu       sia",
          "   che lui/lei  sia",
          "   che noi      siamo",
          "   che voi      siate",
          "   che loro     siano",
          "",
          "AVERE:",
          "   che io       abbia",
          "   che tu       abbia",
          "   che lui/lei  abbia",
          "   che noi      abbiamo",
          "   che voi      abbiate",
          "   che loro     abbiano"
        ]
      },
      {
        "page": 3,
        "total_pages": 5,
        "content": [
          "PRESENT SUBJUNCTIVE — regular endings:",
          "",
          "        -ARE      -ERE      -IRE",
          "io      -i        -a        -a",
          "tu      -i        -a        -a",
          "lui     -i        -a        -a",
          "noi     -iamo     -iamo     -iamo",
          "voi     -iate     -iate     -iate",
          "loro    -ino      -ano      -ano",
          "",
          "EXAMPLES:",
          "   Credo che parli bene.",
          "   I think he speaks well.",
          "   Spero che scriva presto.",
          "   I hope she writes soon.",
          "   Voglio che partano domani.",
          "   I want them to leave tomorrow."
        ]
