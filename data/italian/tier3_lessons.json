        "content": [
          "PASSATO PROSSIMO = past tense for",
          "completed actions ('I did, I have done').",
          "",
          "FORMATION:",
          "   present of avere + past participle",
          "",
          "   ho parlato     = I spoke / have spoken",
          "   hai mangiato   = you ate",
          "   ha visto       = he/she saw",
          "   abbiamo letto  = we read",
          "   avete fatto    = you all did",
          "   hanno detto    = they said",
          "",
          "REGULAR PAST PARTICIPLES:",
          "   -are → -ato    parlare → parlato",
          "   -ere → -uto    vedere → veduto (rare!)",
          "   -ire → -ito    finire → finito"
        ],
        "pronunciation": "Lezione dieci"
      },
      {
        "page": 2,
        "total_pages": 2,
        "content": [
          "COMMON IRREGULAR PAST PARTICIPLES:",
          "",
          "   fare       → fatto       (done/made)",
          "   dire       → detto       (said)",
          "   vedere     → visto       (seen)",
          "   leggere    → letto       (read)",
          "   scrivere   → scritto     (written)",
          "   prendere   → preso       (taken)",
          "   mettere    → messo       (put)",
          "   aprire     → aperto      (opened)",
          "   chiudere   → chiuso      (closed)",
          "   bere       → bevuto      (drunk)",
          "   chiedere   → chiesto     (asked)",
          "   rispondere → risposto    (answered)",
          "   vincere    → vinto       (won)",
          "   perdere    → perso       (lost)",
          "   conoscere  → conosciuto  (known)"
        ]
      }
    ]
