          "PRESENT PERFECT = haber + past participle",
          "Like English 'I have done'.",
          "",
          "HABER conjugation:                   Press 1",
          "he, has, ha, hemos, han",
          "",
          "PAST PARTICIPLES:",
          "-AR → -ado:  hablar → hablado",
          "-ER → -ido:  comer → comido",
          "-IR → -ido:  vivir → vivido",
          "",
          "EXAMPLES:                            Press 2",
          "",
          "He comido. (I have eaten.)",
          "¿Has visto eso? (Have you seen that?)",
          "Hemos terminado. (We have finished.)"
        ],
        "pronunciation": "Lección veinte",
        "pronunciation_mappings": {
          "1": "he, has, ha, hemos, han",
          "2": "he comido, has visto eso, hemos terminado"
        }
      },
      {
        "page": 2,
        "total_pages": 3,
        "content": [
          "IRREGULAR PARTICIPLES — memorize these:",
          "",
          "hacer    → hecho (done)              Press 1",
          "decir    → dicho (said)",
          "ver      → visto (seen)",
          "escribir → escrito (written)",
          "abrir    → abierto (opened)",
          "volver   → vuelto (returned)",
          "romper   → roto (broken)",
          "poner    → puesto (put)",
          "",
          "Pattern: most end in -to or -cho",
          "instead of the regular -ado/-ido.",
          "",
