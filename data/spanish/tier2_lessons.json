          "NO before the verb for negation:     Press 1",
          "",
          "No es difícil. (It's not difficult.)",
          "No hablo francés. (I don't speak French.)",
          "",
          "NEGATIVE WORDS:                      Press 2",
          "nada = nothing    nadie = nobody",
          "nunca = never     ninguno = none",
          "tampoco = neither/not either",
          "",
