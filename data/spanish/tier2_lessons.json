    "header_color": "green",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "Adjectives must AGREE with nouns they describe",
          "",
          "-O/-A adjectives change:             Press 1",
          "el gato blanco  → la gata blanca",
          "los gatos blancos → las gatas blancas",
          "",
          "-E adjectives DON'T change gender:   Press 2",
          "el chico grande  → la chica grande",
          "Only add -s for plural: grandes",
          "",
          "CONSONANT endings — add -a for fem:  Press 3",
          "el chico español → la chica española",
          "",
          "POSITION — usually AFTER the noun:",
          "la casa blanca (the white house)",
          "un libro interesante (an interesting book)",
          "NOTE: A few go BEFORE: bueno, malo, grande",
          "un buen amigo (a good friend)"
        ],
        "pronunciation": "Lección once",
        "pronunciation_mappings": {
          "1": "el gato blanco, la gata blanca, los gatos blancos, las gatas blancas",
          "2": "el chico grande, la chica grande",
          "3": "el chico español, la chica española"
        }
      }
    ]
  },
