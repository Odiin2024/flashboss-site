        "total_pages": 2,
        "content": [
          "ORDINAL NUMBERS (first, second, third...)",
          "Add -a to any number. They're adjectives!",
          "",
          "unua    = first       kvara   = fourth",
          "dua     = second      kvina   = fifth",
          "tria    = third       deka    = tenth",
          "",
          "LARGER ORDINALS:",
          "dudek-unua = twenty-first",
          "centa = hundredth",
