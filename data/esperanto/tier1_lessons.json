    "header_color": "green",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "MAL- is one of Esperanto's most powerful",
          "tools. Put it in front of any word to",
          "create the opposite meaning instantly!",
          "",
          "ADJECTIVES:",
          "bona → malbona      = good → bad",
          "granda → malgranda  = big → small",
          "nova → malnova      = new → old",
          "alta → malalta      = high → low",
          "juna → maljuna      = young → old",
          "",
          "VERBS TOO:",
          "fermi → malfermi    = close → open",
          "ami → malami        = love → hate",
          "",
          "This cuts vocabulary learning in HALF!",
          "Learn 'bona', get 'malbona' free!"
        ],
        "pronunciation": "Leciono naŭ"
      }
    ]
  },
