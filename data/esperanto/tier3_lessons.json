    "header_color": "green",
    "pages": [
      {
        "page": 1,
        "total_pages": 1,
        "content": [
          "The suffix -AN- means \"member of\" or",
          "\"inhabitant of\" or \"follower of.\"",
          "",
          "MEMBERS OF GROUPS:",
          "klubo   → klubano    = club → club member",
          "familio → familiano  = family → family member",
          "",
          "INHABITANTS:",
          "Usono   → Usonano    = USA → American",
          "Eŭropo  → Eŭropano   = Europe → European",
          "urbo    → urbano     = city → city dweller",
          "",
          "FOLLOWERS:",
          "Kristo  → kristano   = Christ → Christian",
          "Budho   → budhano    = Buddha → Buddhist",
          "",
          "ESPERANTO SPECIAL:",
          "samideano = fellow Esperantist",
          "(sam + ideo + ano = same-idea-member)",
          "",
          "-AN- creates belonging and identity!"
        ],
        "pronunciation": "Leciono dudek kvar"
      }
    ]
  }
]
